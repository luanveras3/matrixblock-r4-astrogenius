# Ignore everything by default (whitelist model)
/*
/arduino/*
/resources/*
/resources/app_src/*
/resources/app_src/blockly-core/*
/resources/app_src/blockly-core/msg/*
/resources/app_src/blockly-core/blocks/*
/resources/app_src/views/*

# --- Explicitly include the files we create or patch ---

# Patch and test scripts
!patch_asar.js
!test_app.js
!.gitignore

# Documentation
!README.md
!CHANGELOG.md
!INSTALL.md
!RELEASE.md

# GitHub Actions
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Patched source files
!resources/
!resources/app_src/
!resources/app_src/app.compressed.js
!resources/app_src/blockly-core/
!resources/app_src/blockly-core/msg/
!resources/app_src/blockly-core/msg/scratch_msgs.js
!resources/app_src/blockly-core/blocks/
!resources/app_src/blockly-core/blocks/_mini.js
!resources/app_src/views/
!resources/app_src/views/main.html
!resources/app_src/views/hardware_explorer.html

# New pt-BR block examples (folder did not exist in the upstream app)
!arduino/
!arduino/blocks_examples/
!arduino/blocks_examples/pt-BR/

# Hardware Explorer sketch (uploaded on demand by the desktop app)
!arduino/explorer_sketch/
!arduino/explorer_sketch/*.ino

# Layout assets for the Hardware Explorer panel
!resources/app_src/assets/
!resources/app_src/assets/*.png
!resources/app_src/assets/*.svg
!resources/app_src/assets/*.jpg
# Reference material extracted from proprietary Matrix guidebooks — never commit
resources/app_src/assets/pdf_extract/

# Upstream examples (already shipped in the app; no need to version them)
arduino/blocks_examples/en/
arduino/blocks_examples/zh-cn/
arduino/blocks_examples/zh-tw/
