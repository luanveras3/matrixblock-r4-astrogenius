# Ignore everything by default (whitelist model)
/*
/arduino/*
/resources/*
/resources/app_src/*
/resources/app_src/blockly-core/*
/resources/app_src/blockly-core/msg/*
/resources/app_src/blockly-core/blocks/*
/resources/app_src/views/*

# --- Explicitly include the files we create or patch ---

# Patch and test scripts
!patch_asar.js
!test_app.js
!.gitignore

# Documentation
!README.md
!CHANGELOG.md
!INSTALL.md
!RELEASE.md
!MANUAL_WIFI_TCP_OTA.md
!ROADMAP.md
!docs/
!docs/*.md
!docs/poc/
!docs/poc/**

# WiFi TCP + OTA tooling (bin2ota port, cross-check, fixtures)
!tools/
!tools/bin2ota.js
!tools/bin2ota.test.js
!tools/wifi_wrapper.test.js
!tools/stress_upload_wifi.js
!tools/lzss_ref.py
!tools/fixtures/
!tools/fixtures/blink.bin
!tools/fixtures/UNOR4WIFI_Animation.ota

# WiFi runtime firmware module (delta over the stock MatrixMiniR4 lib).
# Each level re-ignores its children so un-ignoring a directory does not
# drag the whole stock library (a full copy lives untracked in the tree).
!arduino/libraries/
arduino/libraries/*
!arduino/libraries/MatrixMiniR4/
arduino/libraries/MatrixMiniR4/*
!arduino/libraries/MatrixMiniR4/src/
arduino/libraries/MatrixMiniR4/src/*
!arduino/libraries/MatrixMiniR4/src/Modules/
arduino/libraries/MatrixMiniR4/src/Modules/*
!arduino/libraries/MatrixMiniR4/src/Modules/MiniR4WiFiRuntime.h
!arduino/libraries/MatrixMiniR4/src/Modules/MiniR4WiFiRuntime.cpp
!arduino/libraries/MatrixMiniR4/examples/
arduino/libraries/MatrixMiniR4/examples/*
!arduino/libraries/MatrixMiniR4/examples/7-WiFi Runtime/
!arduino/libraries/MatrixMiniR4/examples/7-WiFi Runtime/**
arduino/libraries/MatrixMiniR4/examples/7-WiFi Runtime/**/.build/

# GitHub Actions
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Patched source files
!resources/
!resources/app_src/
!resources/app_src/app.compressed.js
!resources/app_src/blockly-core/
!resources/app_src/blockly-core/msg/
!resources/app_src/blockly-core/msg/scratch_msgs.js
!resources/app_src/blockly-core/blocks/
!resources/app_src/blockly-core/blocks/_mini.js
!resources/app_src/blockly-core/arduino_wifi_wrapper.js
!resources/app_src/blockly-core/wifi_upload.js
!resources/app_src/blockly-core/wifi_hud.js
!resources/app_src/views/
!resources/app_src/views/main.html

# New pt-BR block examples (folder did not exist in the upstream app)
!arduino/
!arduino/blocks_examples/
!arduino/blocks_examples/pt-BR/

# Upstream examples (already shipped in the app; no need to version them)
arduino/blocks_examples/en/
arduino/blocks_examples/zh-cn/
arduino/blocks_examples/zh-tw/
