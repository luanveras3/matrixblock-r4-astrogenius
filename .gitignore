# Ignore everything by default (whitelist model)
/*
/arduino/*
/resources/*
/resources/app_src/*
/resources/app_src/blockly-core/*
/resources/app_src/blockly-core/msg/*
/resources/app_src/blockly-core/blocks/*
/resources/app_src/views/*

# --- Explicitly include the files we create or patch ---

# Patch and test scripts
!patch_asar.js
!test_app.js
!.gitignore

# Documentation
!README.md
!CHANGELOG.md
!INSTALL.md
!RELEASE.md

# GitHub Actions
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Patched source files
!resources/
!resources/app_src/
!resources/app_src/app.compressed.js
!resources/app_src/blockly-core/
!resources/app_src/blockly-core/msg/
!resources/app_src/blockly-core/msg/scratch_msgs.js
!resources/app_src/blockly-core/blocks/
!resources/app_src/blockly-core/blocks/_mini.js
!resources/app_src/views/
!resources/app_src/views/main.html

# New pt-BR block examples (folder did not exist in the upstream app)
!arduino/
!arduino/blocks_examples/
!arduino/blocks_examples/pt-BR/

# Upstream examples (already shipped in the app; no need to version them)
arduino/blocks_examples/en/
arduino/blocks_examples/zh-cn/
arduino/blocks_examples/zh-tw/

# --- BLE runtime library + IDE patch (2026-07-18 session) ---
# Firmware library that turns any USB-flashed sketch into a wireless
# bytecode target, plus the Blockly generator + Web Bluetooth uploader
# that live inside the IDE. See:
#   arduino/libraries/MatrixMiniR4/examples/6-VM Runtime/SESSION_2026-07-18_ALWAYS_ON_BLE.md
!arduino/libraries/
!arduino/libraries/MatrixMiniR4/
!arduino/libraries/MatrixMiniR4/src/
!arduino/libraries/MatrixMiniR4/src/Modules/
!arduino/libraries/MatrixMiniR4/src/Modules/MiniR4BLERuntime.h
!arduino/libraries/MatrixMiniR4/src/Modules/MiniR4BLERuntime.cpp
!arduino/libraries/MatrixMiniR4/examples/
!arduino/libraries/MatrixMiniR4/examples/6-VM Runtime/
!arduino/libraries/MatrixMiniR4/examples/6-VM Runtime/**

# arduino-cli build output produced by flash.ps1 -- do not commit
arduino/libraries/MatrixMiniR4/examples/6-VM Runtime/.build/

# --- BLE stress-test / diagnostics scripts (2026-07-21 session) ---
# Python tooling used to characterize the BLE upload path and RAM
# ceiling. Not needed at runtime; kept versioned so future ceiling
# changes can be re-verified with the same instruments.
!tools/
!tools/*.py
